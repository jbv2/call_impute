/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    withName: SETRG {
        publishDir = [
        path: { "${params.outdir}/rg/" }
        ]
    }

    withName: SAMTOOLS_MERGE {
        publishDir = [
        path: { "${params.outdir}/merged/" }
        ]
    }

    withName: SAMTOOLS_SPLITBAM {
        publishDir = [
        path: { "${params.outdir}/splitted/" }
        ]
    }

    withName: ATLAS_PMD {   
        ext.args = { length="${params.atlas_pmd_length}" }
        publishDir = [
        path: { "${params.outdir}/atlas/pmd" }
        ]
    }

    withName: ATLAS_RECAL {   
        ext.args = { chr="${params.atlas_recal_chr}" }
        publishDir = [
        path: { "${params.outdir}/atlas/recal" }
        ]
    }

    withName: ATLAS_QUALITYTRANSFORMATION {   
        publishDir = [
        path: { "${params.outdir}/atlas/recal" }
        ]
    }

    withName: ATLAS_CALL {   
        ext.args = [
            "infoFields=DP",
            "formatFields=GT,AD,AB,AI,DP,GQ,PL"
        ].join(' ').trim()
        publishDir = [
        path: { "${params.outdir}/atlas/call" }
        ]
    }

    withName: BCFTOOLS_VIEW {   
       publishDir = [
        path: { "${params.outdir}/atlas/call" },
        mode: 'copy'
        ]
    }

    withName: BCFTOOLS_INDEX {   
        ext.args = '--tbi'
        publishDir = [
        path: { "${params.outdir}/bcftools/index" }
        ]
    }

    withName: BCFTOOLS_MERGE {   
        publishDir = [
        path: { "${params.outdir}/bcftools/merge" }
        ]
    }

    withName: GLIMPSE_PHASE {   
        publishDir = [
        path: { "${params.outdir}/glimpse/phase" }
        ]
    }

    withName: INDEX_PHASE {   
        ext.args = '--csi'
        publishDir = [
        path: { "${params.outdir}/glimpse/phase" }
        ]
    }

    withName: GLIMPSE_LIGATE {   
        publishDir = [
        path: { "${params.outdir}/glimpse/ligate" }
        ]
    }

    withName: INDEX_LIGATE {   
        ext.args = '--csi'
        publishDir = [
        path: { "${params.outdir}/glimpse/ligate" }
        ]
    }

    withName: GLIMPSE_SAMPLE {   
        publishDir = [
        path: { "${params.outdir}/glimpse/sample" }
        ]
    }

    withName: INDEX_SAMPLE {   
        ext.args = '--csi'
        publishDir = [
        path: { "${params.outdir}/glimpse/sample" }
        ]
    }

    withName: BCFTOOLS_ANNOTATE {   
        publishDir = [
        path: { "${params.outdir}/bcftools/annotate" },
        mode: 'link'
        ]
    }

    withName: BCFTOOLS_REHEADER {  
        ext.args2 = [
            "-Oz",
            "-W=csi"
        ].join(' ').trim()
        publishDir = [
        path: { "${params.outdir}/bcftools/reheader" },
        mode: 'copy'
        ]
    }

    withName: BCFTOOLS_GET_1240K {   
        publishDir = [
        path: { "${params.outdir}/bcftools/vcfs_1240k" },
        mode: 'copy'
        ]
    }

    withName: BCFTOOLS_MAF_GP {   
        publishDir = [
        path: { "${params.outdir}/bcftools/maf_gp" },
        mode: 'copy'
        ]
    }

    withName: BCFTOOLS_INTERSECTBED {   
        publishDir = [
        path: { "${params.outdir}/bcftools/intersectbed/" },
        mode: 'copy'
        ]
    }

    withName: BCFTOOLS_INTERSECTBED_HIGHCOV {   
        publishDir = [
        path: { "${params.outdir}/bcftools/intersectbed/" }
        ]
    }

    withName: BCFTOOLS_REHEADER_HC {  
        ext.args2 = [
            "-Oz",
            "-W=csi"
        ].join(' ').trim()
        publishDir = [
        path: { "${params.outdir}/bcftools/validation" },
        mode: 'copy'
        ]
    }

}